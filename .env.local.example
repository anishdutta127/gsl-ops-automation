# GSL Ops Automation: dev environment variables.
#
# Copy this file to .env.local and fill in the placeholder values
# from the 1Password "GSL Ops" vault. .env.local is gitignored;
# this .env.local.example is committed and tracked.
#
# Never commit real secrets to git. Never paste real secret values
# into a code review, a Slack message, or a chat log.

# ---------------------------------------------------------------------
# GitHub Contents API token for queue writes.
#
# Used by: src/lib/githubQueue.ts. Every queue commit (PI counter
# advance, pending_updates append) goes through this token.
#
# Source: 1Password "GSL Ops" vault, search "GSL Ops Queue PAT".
# Scope: a fine-grained PAT with Contents: read+write on the
#        anishdutta127/gsl-ops-automation repo only. No org-wide
#        scope; no other repos.
# Rotation: every 90 days. Anish rotates; updates the Vercel env
#           var alongside this local file.
# ---------------------------------------------------------------------
GSL_QUEUE_GITHUB_TOKEN=replace-with-fine-grained-pat-from-1password

# ---------------------------------------------------------------------
# JWT signing secret for the staff session cookie.
#
# Used by: src/lib/crypto/jwt.ts. Signs the gsl_ops_session HS256
# cookie. Must match the value in Vercel prod env vars (otherwise
# the cookie issued in prod will not verify in dev and vice versa,
# which is fine for dev-vs-prod isolation but matters when
# debugging a session-related bug across environments).
#
# Source: 1Password "GSL Ops" vault, search "GSL Ops JWT Secret".
#         Generate a fresh one with: openssl rand -hex 32
# Rotation: every 6 months. Rotation invalidates all live
#           sessions; users will need to log in again.
# ---------------------------------------------------------------------
GSL_JWT_SECRET=replace-with-32-byte-hex-from-1password

# ---------------------------------------------------------------------
# HMAC signing key for SPOC magic links.
#
# Used by: src/lib/magicLink.ts (Week 2 scope; signature shape
# documented in step 8 D7 refinement section). Signs the magic
# link tokens issued in feedback-request and status-portal emails.
# Same key HR uses for candidate magic links; intentional sharing
# so a single rotation covers both repos.
#
# Source: 1Password "GSL Ops" vault, search "GSL Snapshot Signing
#         Key" (the HR-shared key).
# Rotation: yearly. Coordinate with HR before rotating.
# ---------------------------------------------------------------------
GSL_SNAPSHOT_SIGNING_KEY=replace-with-shared-hmac-key-from-1password

# ---------------------------------------------------------------------
# Path to the OneDrive-synced ops-data folder.
#
# Used by: scripts/sync_excel.py (Week 2 scope; read-only ingestion
# from the master xlsx files). Per-machine local path; do NOT
# commit your value.
#
# Source: your local OneDrive sync. The folder lives at:
#         "C:\Users\<user>\OneDrive - MAF TECHNOLOGIES PRIVATE
#         LIMITED\GSL Ops Automation"
#         (or your platform's equivalent)
# Rotation: n/a; per-machine only.
# ---------------------------------------------------------------------
OPS_DATA_PATH=C:\Users\anish\OneDrive - MAF TECHNOLOGIES PRIVATE LIMITED\GSL Ops Automation

# ---------------------------------------------------------------------
# Public app URL (used in magic-link rendering and a few OG tags).
#
# Dev: http://localhost:3000
# Prod: https://ops.getsetlearn.info (or whichever subdomain DNS
#       gets pointed at).
#
# Rotation: n/a unless the public URL changes.
# ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
